NODE_ENV=development
PORT=5000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
MONGO_URI=mongodb://localhost:27017/ets
REDIS_URL=redis://localhost:6379
PUBLIC_BASE_URL=http://localhost:5000
UPLOAD_DIR=uploads
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
FRONTEND_BASE_URL=http://localhost:5173
# 32+ char random string used to encrypt Stripe keys stored in MongoDB
SETTINGS_ENCRYPTION_KEY=change-me-to-a-random-32-plus-character-string
